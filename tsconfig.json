{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["node", "qrcode-terminal", "mime-types", "ws"]
  },
  "include": ["src/index.ts", "src/config.ts", "src/core/**/*", "src/controllers/browser.ts", "src/utils/logger.ts"],
  "exclude": ["node_modules", "dist", "scripts", "img"]
}
